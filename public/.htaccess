<IfModule mod_rewrite.c>
    RewriteEngine On

    # Do not rewrite real files/folders
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Prevent direct access to hidden files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
