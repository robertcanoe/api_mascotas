# Copia a .env y ajusta valores: cp .env.example .env

# --- App ---
APP_ENV=development
APP_DEBUG=true
# URL publica base (sin barra final). En Render puedes omitirla: se usa RENDER_EXTERNAL_URL.
APP_URL=http://localhost/api_mascotas/public
TIMEZONE=UTC

# --- Base de datos (PostgreSQL) ---
# Local / dev
DB_DRIVER=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mascotas_db
DB_USER=postgres
DB_PASS=postgres
DB_CHARSET=UTF8
DB_SCHEMA=public
# Local sin SSL: prefer. Render Postgres: require
DB_SSLMODE=prefer

# --- JWT ---
JWT_SECRET=change-this-in-production
JWT_ISSUER=protectora-api
JWT_TTL=3600

# --- Admin (login API) ---
# Email del admin (debe coincidir con el usuario en BD o con el fallback)
ADMIN_EMAIL=admin@protectora.local
# Genera un hash bcrypt: php -r "echo password_hash('TU_PASSWORD', PASSWORD_BCRYPT), PHP_EOL;"
# Deja vacio en local si usas seed en usuarios; en produccion define un hash seguro.
ADMIN_PASSWORD_HASH=

# --- Render (inyectado automaticamente en el servicio; no hace falta en .env local) ---
# RENDER_EXTERNAL_URL=https://tu-servicio.onrender.com
# DB_SSLMODE=require  (recomendado con Render Postgres)
