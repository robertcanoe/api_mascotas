          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /mascotas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/mascotas"
          }
        },
        {
          "name": "GET /mascotas/{id}",
          "request": {
            "method": "GET",
            "header": [],
